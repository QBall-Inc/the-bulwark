# Logs
logs/*.yaml
logs/*.log
logs/*.md
logs/debug-reports/
logs/diagnostics/*.yaml
logs/validations/*.yaml

# Keep log directories but ignore contents
!logs/.gitkeep
!logs/diagnostics/.gitkeep
!logs/validations/.gitkeep

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/

# Shell profile files (user-specific)
.bash_profile
.bashrc
.profile
.zprofile
.zshrc

# Git config (user-specific)
.gitconfig
.gitmodules

# Ripgrep config
.ripgreprc

# MCP config (user-specific)
.mcp.json

# Claude commands (user-specific)
.claude/commands

# Test task logs
tests/logs/

# Node (if used for testing)
node_modules/
npm-debug.log

# Python (if used for testing)
__pycache__/
*.pyc
.venv/
venv/

# Temporary files
*.tmp
*.bak
tmp/

# Hook control flags (developer-specific)
.claude/enable-pipeline-hooks

# direnv (user-specific environment)
.envrc

# T-044 hook validation fixtures (temporary, cleaned up after validation)
scripts/components/
scripts/hooks/test-agent-hook.sh
scripts/hooks/test-agent-stop.sh

# P4.4 implementer test fixtures (temporary, cleaned up after testing)
scripts/modules/
tests/modules/
tests/fixtures/implementer/

# Infographics (large binary assets, not committed)
Infographics/

# Stale git artifacts (empty files from prior operations)
HEAD
config
objects
refs

# Misc artifacts
report.html
