#!/bin/bash
# claude-project: Launch Claude Code with project-specific task persistence
#
# Usage: claude-project [claude args...]
# Run from within a project directory - auto-detects project and sets task list ID
#
# Installation:
#   1. Copy to a directory in your PATH: cp scripts/claude-project ~/.local/bin/
#   2. Make executable: chmod +x ~/.local/bin/claude-project
#   3. Run from any project directory: cd /path/to/project && claude-project

set -e

# Project detection mapping
# Add new projects here as: "directory-pattern") project_id="task-list-name" ;;
detect_project() {
  case "$PWD" in
    */the-bulwark*)      echo "the-bulwark" ;;
    */clear-framework*)  echo "clear-framework" ;;
    # Add more projects below:
    # */my-other-project*) echo "my-other-project" ;;
    *)                   echo "" ;;
  esac
}

PROJECT_ID=$(detect_project)

if [[ -n "$PROJECT_ID" ]]; then
  echo "Task list: $PROJECT_ID (~/.claude/tasks/$PROJECT_ID/)"
  export CLAUDE_CODE_TASK_LIST_ID="$PROJECT_ID"
else
  echo "No project detected - using session-based tasks"
  echo "Add your project to scripts/claude-project to enable persistence"
fi

# Launch Claude Code with any additional arguments
exec claude "$@"
